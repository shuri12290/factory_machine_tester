<UserControl x:Class="CommTestTool.Views.ExecutionView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="220" MinHeight="120"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0" Margin="8,8,8,0">

            <!-- ── 単体実行 ── -->
            <TabItem Header="単体実行">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="240"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：設定 -->
                    <Border Grid.Column="0" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="▶ 実行" Style="{StaticResource PrimaryBtn}"
                                            Command="{Binding RunCommandCommand}" Width="100" Margin="0,0,8,0"/>
                                    <Button Content="■ 中断" Style="{StaticResource DangerBtn}"
                                            Command="{Binding StopExecutionCommand}" Width="100"/>
                                </StackPanel>
                                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                                           FontSize="13" TextWrapping="Wrap"
                                           Foreground="{StaticResource SecondaryBrush}"/>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="実行設定" Style="{StaticResource SectionHead}"/>
                                    <Label Content="設備"/>
                                    <ComboBox ItemsSource="{Binding Devices, Mode=OneWay}"
                                              SelectedItem="{Binding SelectedDevice}"
                                              DisplayMemberPath="Name" Margin="0,0,0,8"/>
                                    <Label Content="コマンド"/>
                                    <ComboBox ItemsSource="{Binding AvailableCommands, Mode=OneWay}"
                                              SelectedItem="{Binding SelectedCommand}"
                                              DisplayMemberPath="Name" Margin="0,0,0,8"/>
                                    <Separator Margin="0,4,0,8"/>
                                    <TextBlock Text="パラメータ" Style="{StaticResource SectionHead}"/>
                                    <TextBlock Text="（コマンドを選択するとパラメータが表示されます）"
                                               FontSize="11" Foreground="{StaticResource SubBrush}"
                                               Margin="0,0,0,4"
                                               Visibility="{Binding SelectedCommand, Mode=OneWay,
                                                   Converter={StaticResource NullToCollapsed}}"/>
                                    <ItemsControl ItemsSource="{Binding ParamValues, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,10">
                                                    <!-- ラベル行 -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                   Text="{Binding Parameter.Label, Mode=OneWay}"/>
                                                        <Border Background="#E8F0FE" CornerRadius="3"
                                                                Padding="5,1" Margin="6,0,0,0"
                                                                VerticalAlignment="Center">
                                                            <TextBlock FontSize="10"
                                                                       Foreground="{StaticResource PrimaryBrush}"
                                                                       Text="{Binding Parameter.Type, Mode=OneWay}"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- boolean → トグルスイッチ風チェックボックス -->
                                                    <CheckBox IsChecked="{Binding IsBoolValue}"
                                                              Content="true / false" FontSize="13"
                                                              Visibility="{Binding IsBoolType, Mode=OneWay,
                                                                  Converter={StaticResource BoolToVis}}"/>

                                                    <!-- bit → 0/1 トグルボタン -->
                                                    <StackPanel Orientation="Horizontal"
                                                                Visibility="{Binding IsBitType, Mode=OneWay,
                                                                    Converter={StaticResource BoolToVis}}">
                                                        <RadioButton Content="0  OFF" FontSize="13"
                                                                     IsChecked="{Binding IsBitZero}"
                                                                     Margin="0,0,16,0"/>
                                                        <RadioButton Content="1  ON"  FontSize="13"
                                                                     IsChecked="{Binding IsBitOne}"/>
                                                    </StackPanel>

                                                    <!-- integer / long → テキストボックス + ▲▼ -->
                                                    <Grid Visibility="{Binding IsIntType, Mode=OneWay,
                                                              Converter={StaticResource BoolToVis}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0"
                                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                 FontSize="14"/>
                                                        <StackPanel Grid.Column="1">
                                                            <Button Content="▲" FontSize="9" Height="16" Padding="0"
                                                                    Click="ParamIncrement_Click" Tag="{Binding}"/>
                                                            <Button Content="▼" FontSize="9" Height="16" Padding="0"
                                                                    Click="ParamDecrement_Click" Tag="{Binding}"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- byte/word/dword/uint → テキストボックス + ▲▼ + 範囲ヒント -->
                                                    <Grid Visibility="{Binding IsUnsignedType, Mode=OneWay,
                                                              Converter={StaticResource BoolToVis}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0"
                                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                 FontSize="14"/>
                                                        <StackPanel Grid.Column="1">
                                                            <Button Content="▲" FontSize="9" Height="16" Padding="0"
                                                                    Click="ParamIncrementUint_Click" Tag="{Binding}"/>
                                                            <Button Content="▼" FontSize="9" Height="16" Padding="0"
                                                                    Click="ParamDecrementUint_Click" Tag="{Binding}"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- float / double → テキストボックス -->
                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="14"
                                                             Visibility="{Binding IsFloatType, Mode=OneWay,
                                                                 Converter={StaticResource BoolToVis}}"/>

                                                    <!-- json → 複数行テキストボックス -->
                                                    <TextBox Height="80" AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             FontFamily="Courier New" FontSize="12"
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{Binding IsJsonType, Mode=OneWay,
                                                                 Converter={StaticResource BoolToVis}}"/>

                                                    <!-- datetime → テキストボックス + 今時刻ボタン -->
                                                    <Grid Visibility="{Binding IsDateTimeType, Mode=OneWay,
                                                              Converter={StaticResource BoolToVis}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0"
                                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                 FontSize="13"/>
                                                        <Button Grid.Column="1" Content="現在時刻" FontSize="11"
                                                                Padding="6,2" Margin="4,0,0,0"
                                                                Click="ParamNow_Click" Tag="{Binding}"/>
                                                    </Grid>

                                                    <!-- string → テキストボックス -->
                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="14"
                                                             Visibility="{Binding IsStringType, Mode=OneWay,
                                                                 Converter={StaticResource BoolToVis}}"/>

                                                    <!-- ヒントテキスト -->
                                                    <TextBlock FontSize="11" Margin="0,2,0,0"
                                                               Foreground="{StaticResource SubBrush}"
                                                               Text="{Binding TypeHint, Mode=OneWay}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBoolType, Mode=OneWay}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsBitType, Mode=OneWay}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsJsonType, Mode=OneWay}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- バリデーションエラー表示 -->
                                                    <Border Background="#FCE4D6" CornerRadius="3"
                                                            Padding="6,3" Margin="0,3,0,0">
                                                        <TextBlock FontSize="11" Foreground="#C00000"
                                                                   Text="{Binding ValidationError, Mode=OneWay}"
                                                                   TextWrapping="Wrap"/>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasError, Mode=OneWay}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

                    <!-- 右：進捗 -->
                    <Border Grid.Column="2" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="ハンドシェイク進捗"
                                       Style="{StaticResource SectionHead}"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding StepProgresses, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,2" Padding="10,8" CornerRadius="4"
                                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Running">
                                                                <Setter Property="Background" Value="#EBF3FB"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Success">
                                                                <Setter Property="Background" Value="#E2EFDA"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Error">
                                                                <Setter Property="Background" Value="#FCE4D6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <!-- ステップ名行 -->
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   Text="{Binding Duration, Mode=OneWay}"
                                                                   FontSize="11" Foreground="{StaticResource SubBrush}"
                                                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                                                   Visibility="{Binding Duration, Mode=OneWay,
                                                                       Converter={StaticResource EmptyToCollapsed}}"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                                       FontSize="14" Margin="0,0,8,0"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                                                <Run Text="{Binding Index, Mode=OneWay, StringFormat='Step {0}: '}"/>
                                                                <Run Text="{Binding Description, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <!-- 受信データ（read/opcua_method等の戻り値） -->
                                                    <Border Background="#F0F4FF" CornerRadius="3"
                                                            Padding="6,4" Margin="22,4,0,0">
                                                        <TextBlock Text="{Binding ReceivedData, Mode=OneWay}"
                                                                   FontFamily="Courier New" FontSize="11"
                                                                   Foreground="{StaticResource PrimaryBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasReceivedData, Mode=OneWay}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <!-- エラーメッセージ -->
                                                    <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                                                               Foreground="{StaticResource ErrorBrush}"
                                                               FontSize="11" Margin="22,2,0,0"
                                                               TextWrapping="Wrap"
                                                               Visibility="{Binding ErrorMessage, Mode=OneWay,
                                                                   Converter={StaticResource EmptyToCollapsed}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ── シナリオ実行 ── -->
            <TabItem Header="シナリオ実行">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="240"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="▶ 実行" Style="{StaticResource PrimaryBtn}"
                                            Command="{Binding RunScenarioCommand}" Width="100" Margin="0,0,8,0"/>
                                    <Button Content="■ 中断" Style="{StaticResource DangerBtn}"
                                            Command="{Binding StopExecutionCommand}" Width="100"/>
                                </StackPanel>
                                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                                           FontSize="13" TextWrapping="Wrap"
                                           Foreground="{StaticResource SecondaryBrush}"/>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="シナリオ選択" Style="{StaticResource SectionHead}"/>
                                    <Label Content="設備"/>
                                    <ComboBox ItemsSource="{Binding Devices, Mode=OneWay}"
                                              SelectedItem="{Binding SelectedScenarioDevice}"
                                              DisplayMemberPath="Name" Margin="0,0,0,8"/>
                                    <Label Content="シナリオ"/>
                                    <ComboBox ItemsSource="{Binding AvailableScenarios, Mode=OneWay}"
                                              SelectedItem="{Binding SelectedScenario}"
                                              DisplayMemberPath="Name" Margin="0,0,0,12"/>
                                    <Separator Margin="0,0,0,8"/>
                                    <TextBlock Text="パラメータ" Style="{StaticResource SectionHead}"/>
                                    <TextBlock Text="（シナリオを選択するとパラメータが表示されます）"
                                               FontSize="11" Foreground="{StaticResource SubBrush}"
                                               Margin="0,0,0,4"
                                               Visibility="{Binding SelectedScenario, Mode=OneWay,
                                                   Converter={StaticResource NullToCollapsed}}"/>
                                    <ItemsControl ItemsSource="{Binding ScenParamValues, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,10">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                   Text="{Binding Parameter.Label, Mode=OneWay}"/>
                                                        <Border Background="#E8F0FE" CornerRadius="3"
                                                                Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock FontSize="10" Foreground="{StaticResource PrimaryBrush}"
                                                                       Text="{Binding Parameter.Type, Mode=OneWay}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <CheckBox IsChecked="{Binding IsBoolValue}" Content="true / false" FontSize="13"
                                                              Visibility="{Binding IsBoolType, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                                                    <StackPanel Orientation="Horizontal"
                                                                Visibility="{Binding IsBitType, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                                        <RadioButton Content="0  OFF" FontSize="13" IsChecked="{Binding IsBitZero}" Margin="0,0,16,0"/>
                                                        <RadioButton Content="1  ON"  FontSize="13" IsChecked="{Binding IsBitOne}"/>
                                                    </StackPanel>
                                                    <Grid Visibility="{Binding IsIntType, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>
                                                        <StackPanel Grid.Column="1">
                                                            <Button Content="▲" FontSize="9" Height="16" Padding="0" Click="ParamIncrement_Click" Tag="{Binding}"/>
                                                            <Button Content="▼" FontSize="9" Height="16" Padding="0" Click="ParamDecrement_Click" Tag="{Binding}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid Visibility="{Binding IsUnsignedType, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>
                                                        <StackPanel Grid.Column="1">
                                                            <Button Content="▲" FontSize="9" Height="16" Padding="0" Click="ParamIncrementUint_Click" Tag="{Binding}"/>
                                                            <Button Content="▼" FontSize="9" Height="16" Padding="0" Click="ParamDecrementUint_Click" Tag="{Binding}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" FontSize="14"
                                                             Visibility="{Binding IsFloatType, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBox Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                                             FontFamily="Courier New" FontSize="12"
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{Binding IsJsonType, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                                                    <Grid Visibility="{Binding IsDateTimeType, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" FontSize="13"/>
                                                        <Button Grid.Column="1" Content="現在時刻" FontSize="11" Padding="6,2" Margin="4,0,0,0"
                                                                Click="ParamNow_Click" Tag="{Binding}"/>
                                                    </Grid>
                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" FontSize="14"
                                                             Visibility="{Binding IsStringType, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock FontSize="11" Margin="0,2,0,0" Foreground="{StaticResource SubBrush}"
                                                               Text="{Binding TypeHint, Mode=OneWay}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBoolType, Mode=OneWay}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsBitType,  Mode=OneWay}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsJsonType, Mode=OneWay}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <Border Background="#FCE4D6" CornerRadius="3" Padding="6,3" Margin="0,3,0,0">
                                                        <TextBlock FontSize="11" Foreground="#C00000"
                                                                   Text="{Binding ValidationError, Mode=OneWay}" TextWrapping="Wrap"/>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasError, Mode=OneWay}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

                    <Border Grid.Column="2" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="シナリオ進捗"
                                       Style="{StaticResource SectionHead}"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ScenProgresses, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,2" Padding="10,8" CornerRadius="4"
                                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Running">
                                                                <Setter Property="Background" Value="#EBF3FB"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Success">
                                                                <Setter Property="Background" Value="#E2EFDA"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Error">
                                                                <Setter Property="Background" Value="#FCE4D6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                                   FontSize="14" Margin="0,0,8,0"
                                                                   VerticalAlignment="Center"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Step.Description, Mode=OneWay}"
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Foreground="{StaticResource SubBrush}" FontSize="11">
                                                                <Run Text="{Binding Step.Type, Mode=OneWay}"/>
                                                                <Run Text=" / "/>
                                                                <Run Text="{Binding Step.CommandId, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                                                               Foreground="{StaticResource ErrorBrush}"
                                                               FontSize="11" Margin="22,2,0,0"
                                                               TextWrapping="Wrap"
                                                               Visibility="{Binding ErrorMessage, Mode=OneWay,
                                                                   Converter={StaticResource EmptyToCollapsed}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ── 監視 ── -->
            <TabItem Header="👁 監視">
                <Grid x:Name="MonitorGrid" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="240"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：設定 -->
                    <Border Grid.Column="0" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="▶ 開始" Style="{StaticResource PrimaryBtn}"
                                            Command="{Binding StartCommand}" Width="100" Margin="0,0,8,0"/>
                                    <Button Content="■ 停止" Style="{StaticResource DangerBtn}"
                                            Command="{Binding StopCommand}" Width="100"/>
                                </StackPanel>
                                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                                           FontSize="13" TextWrapping="Wrap"
                                           Foreground="{StaticResource SecondaryBrush}"/>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="監視設定" Style="{StaticResource SectionHead}"/>
                                    <Label Content="設備"/>
                                    <ComboBox ItemsSource="{Binding Devices, Mode=OneWay}"
                                              SelectedItem="{Binding SelectedDevice}"
                                              DisplayMemberPath="Name" Margin="0,0,0,8"/>
                                    <Label Content="コマンド（pollステップを持つもの）"/>
                                    <ComboBox ItemsSource="{Binding AvailableCommands, Mode=OneWay}"
                                              SelectedItem="{Binding SelectedCommand}"
                                              DisplayMemberPath="Name" Margin="0,0,0,8"/>
                                    <Label Content="pollステップ"/>
                                    <ComboBox ItemsSource="{Binding AvailablePollSteps, Mode=OneWay}"
                                              SelectedItem="{Binding SelectedPollStep}"
                                              DisplayMemberPath="Description" Margin="0,0,0,12"/>
                                    <Separator Margin="0,0,0,8"/>

                                    <!-- パラメータ入力（間隔・タイムアウト等） -->
                                    <TextBlock Text="パラメータ入力"
                                               Style="{StaticResource SectionHead}"
                                               Visibility="{Binding SelectedCommand, Mode=OneWay,
                                                   Converter={StaticResource NullToCollapsed}}"/>
                                    <ItemsControl ItemsSource="{Binding ParamValues, Mode=OneWay}"
                                                  Margin="0,0,0,8"
                                                  Visibility="{Binding SelectedCommand, Mode=OneWay,
                                                      Converter={StaticResource NullToCollapsed}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                   Text="{Binding Parameter.Label, Mode=OneWay}"/>
                                                        <TextBlock FontSize="11" Margin="4,0,0,0"
                                                                   Foreground="{StaticResource SubBrush}"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="("/>
                                                            <Run Text="{Binding Parameter.Type, Mode=OneWay}"/>
                                                            <Run Text=")"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <CheckBox Margin="0,2,0,0"
                                                              IsChecked="{Binding IsBoolValue}"
                                                              Content="true / false"
                                                              Visibility="{Binding IsBoolType, Mode=OneWay,
                                                                  Converter={StaticResource BoolToVis}}"/>
                                                    <TextBox Margin="0,2,0,0"
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{Binding IsTextType, Mode=OneWay,
                                                                 Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource SubBrush}"
                                                               Text="{Binding TypeHint, Mode=OneWay}"
                                                               Visibility="{Binding IsTextType, Mode=OneWay,
                                                                   Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Separator Margin="0,0,0,8"/>
                                    <TextBlock Text="接続設定（pollステップから自動入力）"
                                               Style="{StaticResource SectionHead}"/>
                                    <Label Content="接続口ID"/>
                                    <TextBox Text="{Binding ConnectionId, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,8"/>
                                    <Label Content="ノードID / アドレス"/>
                                    <TextBox Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="True" Foreground="{StaticResource SubBrush}"
                                             Margin="0,0,0,4"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource SubBrush}"
                                               Margin="0,0,0,8" TextWrapping="Wrap"
                                               Text="pollステップ選択時に自動設定されます"/>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

                    <!-- 右：現在値 + 履歴 -->
                    <Border Grid.Column="2" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12">
                        <DockPanel>
                            <!-- 現在値 -->
                            <Border DockPanel.Dock="Top" Padding="12,10" CornerRadius="4"
                                    Margin="0,0,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning, Mode=OneWay}" Value="True">
                                                <Setter Property="Background" Value="#E2EFDA"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasError, Mode=OneWay}" Value="True">
                                                <Setter Property="Background" Value="#FCE4D6"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding LastUpdated, Mode=OneWay,
                                                       StringFormat='最終取得: HH:mm:ss.fff'}"
                                                   Foreground="{StaticResource SubBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <Border Margin="0,8,0,0" Padding="10,6" CornerRadius="3"
                                            Background="White"
                                            Visibility="{Binding IsRunning, Mode=OneWay,
                                                Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="現在値：" FontSize="12"
                                                       Foreground="{StaticResource SubBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding CurrentValue, Mode=OneWay}"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- 複数ノード最新値一覧（HasMultipleNodes=True のときのみ表示） -->
                                    <Border Margin="0,8,0,0" Padding="10,8" CornerRadius="3"
                                            Background="White"
                                            Visibility="{Binding HasMultipleNodes, Mode=OneWay,
                                                Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="各ノード最新値" FontSize="11"
                                                       Foreground="{StaticResource SubBrush}"
                                                       Margin="0,0,0,6"/>
                                            <ItemsControl ItemsSource="{Binding NodeValues, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding NodeId, Mode=OneWay}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource SubBrush}"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding Value, Mode=OneWay}"
                                                                       FontSize="14" FontWeight="Bold"
                                                                       Foreground="{StaticResource PrimaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 履歴 -->
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                    <TextBlock Text="取得履歴（最新1000件）"
                                               Style="{StaticResource SectionHead}" VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" Content="クリア"
                                            Style="{StaticResource SmallBtn}"
                                            Command="{Binding ClearHistoryCommand}"/>
                                </DockPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding History, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontFamily="Courier New" FontSize="11"
                                                           Text="{Binding ., Mode=OneWay}"
                                                           Margin="0,1" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsError, Mode=OneWay}" Value="True">
                                                                    <Setter Property="Foreground"
                                                                            Value="{StaticResource ErrorBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"/>

        <!-- ログ -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" Margin="8,0,8,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <DockPanel Margin="12,8">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <TextBlock Text="実行ログ" Style="{StaticResource SectionHead}"
                               VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="クリア"
                            Style="{StaticResource SmallBtn}"
                            Command="{Binding ClearLogCommand}"/>
                </DockPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogEntries, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Courier New" FontSize="11"
                                           Text="{Binding ., Mode=OneWay}"
                                           TextWrapping="Wrap" Margin="0,1">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level, Mode=OneWay}" Value="Error">
                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level, Mode=OneWay}" Value="Success">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level, Mode=OneWay}" Value="Warning">
                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
