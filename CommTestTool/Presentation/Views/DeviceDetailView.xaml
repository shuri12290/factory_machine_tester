<UserControl x:Class="CommTestTool.Views.DeviceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CommTestTool.Views"
             xmlns:vm="clr-namespace:CommTestTool.Presentation.ViewModels"
             xmlns:v="clr-namespace:CommTestTool.Views">

    <UserControl.Resources>
        <!-- コマンド詳細 -->
        <DataTemplate DataType="{x:Type vm:CommandDetailViewModel}">
            <v:CommandDetailView/>
        </DataTemplate>
        <!-- シナリオ詳細 -->
        <DataTemplate DataType="{x:Type vm:ScenarioDetailViewModel}">
            <v:ScenarioDetailView/>
        </DataTemplate>
        <!-- 接続口詳細 -->
        <DataTemplate DataType="{x:Type vm:ConnectionEditItem}">
            <v:ConnectionDetailView/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左ペイン：設備情報 + コマンド/シナリオ一覧 -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource CardBrush}">
            <StackPanel Margin="12">

                <!-- ヘッダー -->
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="設備の詳細" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="💾 保存"
                            Style="{StaticResource PrimaryBtn}"
                            Command="{Binding SaveCommand}"/>
                </DockPanel>

                <!-- エラーバナー -->
                <Border Background="#FCE4D6" BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,0,8"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                               Foreground="{StaticResource ErrorBrush}" FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <!-- 基本情報 -->
                <Border Background="#EBF3FB" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="基本情報" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                        <Label Content="設備ID"/>
                        <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                        <Label Content="設備名"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- 接続口 -->
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="接続口" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="＋"
                                    Style="{StaticResource SmallBtn}"
                                    Command="{Binding AddConnectionCommand}"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding Connections, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- コマンド・シナリオと同じスタイルのクリック選択行 -->
                                    <Border Margin="0,0,0,4" CornerRadius="4" Padding="8,6"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <local:EqualityConverter/>
                                                                </MultiBinding.Converter>
                                                                <Binding Path="DataContext.SelectedConnection"
                                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="#EBF3FB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.EditConnectionCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{StaticResource AccentBrush}"
                                                    CornerRadius="3" Padding="5,2" Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Protocol, Mode=OneWay}"
                                                           Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Id, Mode=OneWay}"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Content="🗑"
                                                    Style="{StaticResource DangerBtn}"
                                                    Command="{Binding DataContext.DeleteConnectionCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="接続口をクリックすると右側で編集できます"
                                   FontSize="11" Foreground="{StaticResource SubBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- コマンド一覧 -->
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="コマンド" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="＋" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"
                                        Command="{Binding AddCommandCommand}"/>
                                <Button Content="コピー" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"
                                        Command="{Binding CopyCommandCommand}"
                                        CommandParameter="{Binding SelectedCommand}"/>
                                <Button Content="🗑" Style="{StaticResource DangerBtn}"
                                        Command="{Binding DeleteCommandCommand}"
                                        CommandParameter="{Binding SelectedCommand}"/>
                            </StackPanel>
                        </DockPanel>
                        <ListBox ItemsSource="{Binding Commands, Mode=OneWay}"
                                 SelectedItem="{Binding SelectedCommand}"
                                 MaxHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                   FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Foreground="{StaticResource SubBrush}" FontSize="10">
                                            <Run Text="{Binding Steps.Count, Mode=OneWay}"/>
                                            <Run Text=" ステップ"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- シナリオ一覧 -->
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="シナリオ" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="＋" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"
                                        Command="{Binding AddScenarioCommand}"/>
                                <Button Content="コピー" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"
                                        Command="{Binding CopyScenarioCommand}"
                                        CommandParameter="{Binding SelectedScenario}"/>
                                <Button Content="🗑" Style="{StaticResource DangerBtn}"
                                        Command="{Binding DeleteScenarioCommand}"
                                        CommandParameter="{Binding SelectedScenario}"/>
                            </StackPanel>
                        </DockPanel>
                        <ListBox ItemsSource="{Binding Scenarios, Mode=OneWay}"
                                 SelectedItem="{Binding SelectedScenario}"
                                 MaxHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                   FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Foreground="{StaticResource SubBrush}" FontSize="10">
                                            <Run Text="{Binding Steps.Count, Mode=OneWay}"/>
                                            <Run Text=" ステップ"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

        <!-- 右ペイン：コマンド/シナリオ詳細（SubDetailViewModelに応じて自動切替）-->
        <Border Grid.Column="2" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <Grid>
                <TextBlock Text="コマンドまたはシナリオを選択してください"
                           Foreground="{StaticResource SubBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SubDetailViewModel, Mode=OneWay,
                                    Converter={StaticResource NullToCollapsed}}" Value="Collapsed">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ContentControl Content="{Binding SubDetailViewModel, Mode=OneWay}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
