<Window x:Class="CommTestTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CommTestTool.Presentation.ViewModels"
        xmlns:v="clr-namespace:CommTestTool.Views"
        Title="工場設備 通信テストツール"
        Height="800" Width="1280" MinHeight="600" MinWidth="900"
        Background="{StaticResource BgBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DeviceDetailViewModel}">
            <v:DeviceDetailView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- ヘッダー -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="16,10">
            <DockPanel LastChildFill="True">
                <!-- DockPanel.Dock="Right" は先に宣言したほうが外側（右端）になる -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📥 インポート" Margin="0,0,6,0"
                            Command="{Binding ImportCommand}"
                            Padding="10,4" FontSize="12" Width="110"
                            Background="Transparent" Foreground="White"
                            BorderBrush="White" BorderThickness="1"/>
                    <Button Content="📤 エクスポート"
                            Command="{Binding ExportCommand}"
                            Padding="10,4" FontSize="12" Width="110"
                            Background="Transparent" Foreground="White"
                            BorderBrush="White" BorderThickness="1"/>
                </StackPanel>
                <TextBlock Text="工場設備 通信テストツール"
                           Foreground="White" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                    Background="Transparent" BorderThickness="0" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding"  Value="20,8"/>
                </Style>
            </TabControl.Resources>

            <!-- ⚙ 設定タブ -->
            <TabItem Header="⚙ 設定"
                     IsEnabled="{Binding IsSettingEnabled, Mode=OneWay}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" MinWidth="160"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：設備リスト -->
                    <Border Grid.Column="0" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                        <v:DeviceListView DataContext="{Binding DeviceListVM}"/>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

                    <!-- 右：設備詳細（DataTemplateで自動表示）-->
                    <Border Grid.Column="2" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0" Margin="0">
                        <Grid>
                            <TextBlock Text="左のリストから設備を選択してください"
                                       Foreground="{StaticResource SubBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DetailViewModel, Mode=OneWay,
                                                Converter={StaticResource NullToCollapsed}}"
                                                Value="Collapsed">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ContentControl Content="{Binding DetailViewModel, Mode=OneWay}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ▶ 実行タブ -->
            <TabItem Header="▶ 実行">
                <v:ExecutionView DataContext="{Binding ExecutionVM}"/>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
