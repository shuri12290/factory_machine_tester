<Window x:Class="CommTestTool.Views.WaitStepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="待機ステップ追加" Width="400" Height="240"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="追加" Style="{StaticResource PrimaryBtn}"
                    Click="OK_Click" Width="80" Margin="0,0,8,0"/>
            <Button Content="キャンセル" Click="Cancel_Click" Width="80" Padding="8,6"/>
        </StackPanel>
        <StackPanel>
            <Label Content="待機時間（ミリ秒）"/>
            <TextBox x:Name="DurationBox" Text="2000" Margin="0,0,0,8"/>
            <TextBlock Text="1000 = 1秒、2000 = 2秒" FontSize="11"
                       Foreground="{StaticResource SubBrush}"/>
        </StackPanel>
    </DockPanel>
</Window>
