<UserControl x:Class="CommTestTool.Views.CommandDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <DockPanel Margin="0,0,0,12">
                <TextBlock Text="コマンドの詳細" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="💾 保存"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryBtn}"
                        Padding="14,6" FontSize="13"/>
            </DockPanel>

            <Border Background="#FCE4D6" BorderBrush="{StaticResource ErrorBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,0,8"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                           Foreground="{StaticResource ErrorBrush}" FontSize="11" TextWrapping="Wrap"/>
            </Border>

            <Border Background="#EBF3FB" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="基本情報" Style="{StaticResource SectionHead}"/>
                    <Label Content="コマンドID"/>
                    <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                    <TextBlock Text="例: machine_instruction_01"
                               FontSize="11" Foreground="{StaticResource SubBrush}" Margin="0,0,0,8"/>
                    <Label Content="コマンド名"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="パラメータ" Style="{StaticResource SectionHead}" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="＋" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"
                                    Command="{Binding AddParameterCommand}"/>
                            <Button Content="🗑 最後を削除" Style="{StaticResource DangerBtn}"
                                    Command="{Binding DeleteParameterCommand}"/>
                        </StackPanel>
                    </DockPanel>
                    <Border Background="{StaticResource PrimaryBrush}" Padding="8,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="変数名" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="表示名" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="型"     Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="（パラメータを追加するには ＋ ボタンを押してください）"
                                   FontSize="11" Foreground="{StaticResource SubBrush}"
                                   Margin="0,4,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Parameters.Count, Mode=OneWay}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Parameters, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1" Padding="8,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding Name,  UpdateSourceTrigger=LostFocus}" BorderThickness="0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Label, UpdateSourceTrigger=LostFocus}" BorderThickness="0"/>
                                        <ComboBox Grid.Column="2"
                                                  SelectedValue="{Binding Type}"
                                                  SelectedValuePath="Content"
                                                  BorderThickness="0">
                                            <ComboBoxItem Content="string"  ToolTip="文字列 (デフォルト)"/>
                                            <ComboBoxItem Content="integer" ToolTip="整数 int32 (-2^31〜2^31-1)"/>
                                            <ComboBoxItem Content="float"   ToolTip="浮動小数点 (単精度)"/>
                                            <ComboBoxItem Content="double"  ToolTip="浮動小数点 (倍精度・高精度)"/>
                                            <ComboBoxItem Content="boolean" ToolTip="真偽値 (true/false)"/>
                                            <ComboBoxItem Content="byte"    ToolTip="1バイト整数 (0〜255) PMC向け"/>
                                            <ComboBoxItem Content="word"    ToolTip="2バイト整数 (0〜65535) SLMP/PMC向け"/>
                                            <ComboBoxItem Content="dword"   ToolTip="4バイト整数 (0〜4294967295) SLMP向け"/>
                                            <ComboBoxItem Content="long"    ToolTip="64bit整数 OPC-UA向け"/>
                                            <ComboBoxItem Content="uint"    ToolTip="符号なし整数 (0〜4294967295) OPC-UA/SLMP向け"/>
                                            <ComboBoxItem Content="bit"     ToolTip="ビット値 (0 or 1) SLMP/PMC向け"/>
                                            <ComboBoxItem Content="datetime" ToolTip="日時 ISO8601形式 (例: 2024-01-01T12:00:00) OPC-UA向け"/>
                                            <ComboBoxItem Content="json"    ToolTip="JSONオブジェクト (TCP/MQTT向け・複雑な構造体)"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="ステップ" Style="{StaticResource SectionHead}" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="＋ 追加"
                                Style="{StaticResource SmallBtn}" Command="{Binding AddStepCommand}"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Steps, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="3" Margin="0,0,0,4" Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource AccentBrush}"
                                                CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Action, Mode=OneWay}"
                                                       Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Description, Mode=OneWay}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ConnectionId, Mode=OneWay}"
                                                       Foreground="{StaticResource SubBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Content="↑" Style="{StaticResource SmallBtn}" Margin="2,0"
                                                    Command="{Binding DataContext.MoveStepUpCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="↓" Style="{StaticResource SmallBtn}" Margin="2,0"
                                                    Command="{Binding DataContext.MoveStepDownCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="✎" Style="{StaticResource SmallBtn}" Margin="2,0"
                                                    Command="{Binding DataContext.EditStepCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="🗑" Style="{StaticResource DangerBtn}" Margin="2,0"
                                                    Command="{Binding DataContext.DeleteStepCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
