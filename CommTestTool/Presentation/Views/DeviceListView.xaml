<UserControl x:Class="CommTestTool.Views.DeviceListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="6">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="＋" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"
                    Command="{Binding AddCommand}"/>
            <Button Content="コピー" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"
                    Command="{Binding CopyCommand}"
                    CommandParameter="{Binding SelectedDevice}"/>
            <Button Content="🗑" Style="{StaticResource DangerBtn}"
                    Command="{Binding DeleteCommand}"
                    CommandParameter="{Binding SelectedDevice}"/>
        </StackPanel>
        <ListBox ItemsSource="{Binding Devices, Mode=OneWay}"
                 SelectedItem="{Binding SelectedDevice}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                   FontWeight="SemiBold" FontSize="13"/>
                        <ItemsControl ItemsSource="{Binding Connections, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="11"
                                               Foreground="{StaticResource SubBrush}"
                                               Margin="8,1,0,0">
                                        <Run Text="{Binding Protocol, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding Id, Mode=OneWay}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
