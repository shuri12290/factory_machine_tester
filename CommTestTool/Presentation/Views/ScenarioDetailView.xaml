<UserControl x:Class="CommTestTool.Views.ScenarioDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <DockPanel Margin="0,0,0,12">
                <TextBlock Text="シナリオの詳細" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="💾 保存"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryBtn}"
                        Padding="14,6" FontSize="13"/>
            </DockPanel>

            <Border Background="#FCE4D6" BorderBrush="{StaticResource ErrorBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,0,8"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                           Foreground="{StaticResource ErrorBrush}" FontSize="11" TextWrapping="Wrap"/>
            </Border>

            <Border Background="#EBF3FB" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="基本情報" Style="{StaticResource SectionHead}"/>
                    <Label Content="シナリオID"/>
                    <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                    <Label Content="シナリオ名"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="ステップ" Style="{StaticResource SectionHead}" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="＋ コマンド" Style="{StaticResource SmallBtn}"
                                    Command="{Binding AddCommandStepCommand}" Margin="0,0,4,0"/>
                            <Button Content="＋ 待機" Style="{StaticResource SmallBtn}"
                                    Command="{Binding AddWaitStepCommand}"/>
                        </StackPanel>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Steps, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="3" Margin="0,0,0,4" Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="3"
                                                Padding="6,2" Margin="0,0,8,0"
                                                Background="{StaticResource SecondaryBrush}">
                                            <TextBlock Text="{Binding Type, Mode=OneWay}"
                                                       Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Description, Mode=OneWay}" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="{StaticResource SubBrush}" FontSize="11">
                                                <Run Text="{Binding CommandId, Mode=OneWay}"/>
                                                <Run Text="{Binding DurationMs, Mode=OneWay, StringFormat=' {0}ms'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Content="↑" Style="{StaticResource SmallBtn}" Margin="2,0"
                                                    Command="{Binding DataContext.MoveStepUpCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="↓" Style="{StaticResource SmallBtn}" Margin="2,0"
                                                    Command="{Binding DataContext.MoveStepDownCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="🗑" Style="{StaticResource DangerBtn}" Margin="2,0"
                                                    Command="{Binding DataContext.DeleteStepCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
