<Application x:Class="CommTestTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CommTestTool">
    <Application.Resources>
        <!-- コンバーター -->
        <local:InverseBoolConverter     x:Key="InverseBool"/>
        <local:BoolToVisConverter       x:Key="BoolToVis"/>
        <local:NullToCollapsedConverter x:Key="NullToCollapsed"/>
        <local:StringEmptyToCollapsedConverter x:Key="EmptyToCollapsed"/>

        <!-- カラー -->
        <SolidColorBrush x:Key="PrimaryBrush"   Color="#1F4E79"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#2E75B6"/>
        <SolidColorBrush x:Key="AccentBrush"    Color="#4472C4"/>
        <SolidColorBrush x:Key="SuccessBrush"   Color="#70AD47"/>
        <SolidColorBrush x:Key="ErrorBrush"     Color="#C00000"/>
        <SolidColorBrush x:Key="WarningBrush"   Color="#ED7D31"/>
        <SolidColorBrush x:Key="BgBrush"        Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBrush"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush"    Color="#BFBFBF"/>
        <SolidColorBrush x:Key="TextBrush"      Color="#2B2B2B"/>
        <SolidColorBrush x:Key="SubBrush"       Color="#666666"/>

        <!-- ボタン -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Padding"  Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- テキストボックス -->
        <Style TargetType="TextBox">
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>
        <!-- コンボボックス -->
        <Style TargetType="ComboBox">
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>
        <!-- ラベル -->
        <Style TargetType="Label">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding"    Value="0,4,8,2"/>
        </Style>
        <!-- セクション見出し -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
    </Application.Resources>
</Application>
